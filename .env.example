# ==========================================================
#  Bolão Charlão Copa 2026 — modelo de variáveis de ambiente
#  Copie para .env e preencha com seus valores reais.
# ==========================================================

# Ambiente: dev | prod
ENV=dev

# Banco de dados (Neon) — conexão DIRETA (não-pooled).
# Prefixo postgresql+psycopg para SQLAlchemy/SQLModel.
DATABASE_URL=postgresql+psycopg://USUARIO:SENHA@HOST/BANCO?sslmode=require
DATABASE_URL_PROD=postgresql+psycopg://USUARIO:SENHA@HOST/BANCO?sslmode=require

# Chave para assinar tokens de sessão (JWT).
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=troque-por-uma-chave-aleatoria-forte

# Exibição de horários
TZ_DISPLAY=America/Sao_Paulo

# Bootstrap do admin (script scripts/criar_admin.py)
ADMIN_NOME=
ADMIN_APELIDO=
ADMIN_EMAIL=
ADMIN_SENHA=
